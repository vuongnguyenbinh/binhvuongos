package components

templ DateFilter() {
	<div class="flex items-center gap-2 text-xs">
		<span class="eyebrow">Từ</span>
		<input type="date" value="2026-04-01" class="px-2 py-1.5 border border-hairline dark:border-dark-border rounded bg-surface dark:bg-dark-surface text-sm"/>
		<span class="eyebrow">đến</span>
		<input type="date" value="2026-04-30" class="px-2 py-1.5 border border-hairline dark:border-dark-border rounded bg-surface dark:bg-dark-surface text-sm"/>
	</div>
}
